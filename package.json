{
  "name": "taste.md",
  "version": "0.1.0",
  "description": "Generate evidence-backed taste.md files from pull request history.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "taste-md": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "test": "node --test test/*.test.mjs",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "agents",
    "claude",
    "codex",
    "taste",
    "pull-requests"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
